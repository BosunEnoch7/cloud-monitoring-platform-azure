# Azure Storage backend values for approved local troubleshooting.
# GitHub Actions supplies these values from repository variables.

resource_group_name  = "cloud-monitoring-tfstate-rg"
storage_account_name = "REPLACE_WITH_GLOBALLY_UNIQUE_NAME"
container_name       = "tfstate"
key                  = "cloud-monitoring/dev.tfstate"
use_azuread_auth     = true
use_oidc             = false
