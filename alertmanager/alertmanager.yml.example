global:
  resolve_timeout: 5m
  smtp_smarthost: "SMTP_HOST:SMTP_PORT"
  smtp_from: "SENDER_EMAIL"
  smtp_auth_username: "SMTP_USERNAME"
  smtp_auth_password: "REPLACE_WITH_APP_PASSWORD"
  smtp_require_tls: true

route:
  receiver: email-operations
  group_by:
    - alertname
    - environment
    - instance
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  routes:
    - receiver: email-operations
      matchers:
        - severity="critical"
      repeat_interval: 1h
    - receiver: email-operations
      matchers:
        - severity="warning"
      repeat_interval: 4h

receivers:
  - name: email-operations
    email_configs:
      - to: "RECIPIENT_EMAIL"
        send_resolved: true
        headers:
          subject: '[{{ .Status | toUpper }}] {{ .CommonLabels.alertname }} - {{ .CommonLabels.environment }}'

inhibit_rules:
  - source_matchers:
      - severity="critical"
    target_matchers:
      - severity="warning"
    equal:
      - alertname
      - instance
